{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/example/self-learning-organizations/schema/source.schema.json",
  "title": "Canonical corpus source",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "platform", "stable_id", "title", "publisher", "canonical_url", "published_date", "content_type", "status", "relevance_status", "provenance", "rights_status", "rights_holder", "content_sha256"],
  "properties": {
    "schema_version": {"const": 1},
    "platform": {"enum": ["youtube", "arxiv", "x", "reddit", "substack", "blogs", "podcasts", "conferences", "books", "case-studies"]},
    "stable_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "publisher": {"type": "string", "minLength": 1},
    "canonical_url": {"type": "string", "format": "uri", "pattern": "^https?://"},
    "published_date": {"type": "string", "format": "date"},
    "duration_seconds": {"type": "integer", "minimum": 1},
    "content_type": {"enum": ["transcript", "paper", "post", "article", "episode", "talk", "book", "case-study"]},
    "status": {"enum": ["accepted", "rejected"]},
    "relevance_status": {"enum": ["relevant", "irrelevant"]},
    "provenance": {"type": "string", "minLength": 1},
    "rights_status": {"enum": ["third-party", "licensed", "public-domain", "permission-granted"]},
    "rights_holder": {"type": "string", "minLength": 1},
    "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "transcript_source": {"type": "string"},
    "rejection_reason": {"type": "string"},
    "availability": {"type": "string", "minLength": 1},
    "license": {"type": ["string", "null"]},
    "caption_error": {"type": ["string", "null"]},
    "segment_count": {"type": "integer", "minimum": 5},
    "relevance_categories": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "relevance_evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "relevance_spans": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "rights_note": {"type": "string", "minLength": 1},
    "raw_files": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}},
    "raw_path": {"type": "string", "minLength": 1},
    "asr_models": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
